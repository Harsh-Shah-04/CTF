# Copy to .env and adjust for your setup.
# Local Supabase (free): run `npx supabase start` first.

# --- CTFd database (PostgreSQL via Supabase) ---
# Native Python (serve.py / flask run):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/ctfd

# Docker Compose (docker-compose.supabase.yml uses host.docker.internal):
# DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/ctfd

# --- Optional: Supabase cloud free tier (instead of local) ---
# Create a project at https://supabase.com → Settings → Database → Connection string
# Use the "URI" format and replace [YOUR-PASSWORD]:
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- Redis (optional; CTFd falls back to filesystem cache without it) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Supabase API (for future client integrations; from `npx supabase status`) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- CTFd admin bootstrap (optional) ---
# PRESET_ADMIN_NAME=admin
# PRESET_ADMIN_EMAIL=admin@example.com
# PRESET_ADMIN_PASSWORD=changeme
